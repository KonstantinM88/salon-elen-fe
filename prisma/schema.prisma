generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Article {
  id             String               @id @default(cuid())
  slug           String               @unique
  title          String
  excerpt        String?
  cover          String?
  type           ArticleType          @default(NEWS)
  content        String?
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  seoTitle       String?
  seoDescription String?
  ogTitle        String?
  ogDescription  String?
  ogImage        String?
  isPinned       Boolean              @default(false)
  sortOrder      Int                  @default(0)
  videoUrl       String?
  videoType      VideoType?
  translations   ArticleTranslation[]

  @@index([publishedAt])
  @@index([expiresAt])
  @@index([isPinned(sort: Desc), sortOrder(sort: Desc), publishedAt(sort: Desc)])
}

model ArticleTranslation {
  id             String   @id @default(cuid())
  articleId      String
  locale         String
  title          String
  excerpt        String?
  content        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  seoTitle       String?
  seoDescription String?
  ogTitle        String?
  ogDescription  String?
  article        Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([locale])
  @@index([articleId])
  @@map("article_translations")
}

model Booking {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  message   String?
  createdAt DateTime @default(now())
}

model Service {
  id                    String                 @id @default(cuid())
  slug                  String                 @unique
  priceCents            Int?
  durationMin           Int
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  isActive              Boolean                @default(true)
  parentId              String?
  /// Мягкое удаление: скрываем из интерфейса,
  /// данные и связи остаются (для истории).
  isArchived            Boolean                @default(false)
  name                  String                 @map("title")
  description           String?
  cover                 String?
  appointments          Appointment[]
  promotionItems        PromotionItem[]
  parent                Service?               @relation("ServiceChildren", fields: [parentId], references: [id])
  children              Service[]              @relation("ServiceChildren")
  smsPhoneRegistrations SmsPhoneRegistration[]
  gallery               ServiceGallery[]
  translations          ServiceTranslation[]
  masters               Master[]               @relation("MasterServices")

  @@index([isActive])
  @@index([isArchived])
  @@index([slug])
  @@index([parentId])
  @@map("Service")
}

model ServiceTranslation {
  id          String   @id @default(cuid())
  serviceId   String
  locale      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, locale])
  @@index([locale])
  @@index([serviceId])
  @@map("service_translations")
}

model ServiceGallery {
  id        String   @id @default(cuid())
  serviceId String
  image     String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_gallery")
}

model Client {
  id           String          @id @default(cuid())
  name         String
  phone        String          @unique
  email        String          @unique
  birthDate    DateTime
  referral     String?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  userId       String?         @unique
  deletedAt    DateTime?       @db.Timestamp(6)
  deletedBy    String?
  appointments Appointment[]
  user         User?           @relation(fields: [userId], references: [id])
  discount     ClientDiscount?

  @@index([phone])
  @@index([email])
  @@index([deletedAt])
  @@map("Client")
}

model Master {
  id                    String                 @id @default(cuid())
  name                  String
  email                 String                 @unique
  phone                 String                 @unique
  birthDate             DateTime
  bio                   String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  avatarUrl             String?
  userId                String?                @unique
  appointments          Appointment[]
  user                  User?                  @relation(fields: [userId], references: [id])
  timeOff               MasterTimeOff[]
  workingHours          MasterWorkingHours[]
  smsPhoneRegistrations SmsPhoneRegistration[]
  services              Service[]              @relation("MasterServices")
}

model MasterWorkingHours {
  id           String   @id @default(cuid())
  masterId     String
  /// 0 = Sunday ... 6 = Saturday
  weekday      Int
  startMinutes Int
  endMinutes   Int
  isClosed     Boolean  @default(false)
  createdAt    DateTime @default(now())
  master       Master   @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@unique([masterId, weekday])
}

model MasterTimeOff {
  id           String   @id @default(cuid())
  masterId     String
  /// Дата (обычно полночь локальной TZ) + интервал
  date         DateTime
  startMinutes Int
  endMinutes   Int
  reason       String?
  createdAt    DateTime @default(now())
  master       Master   @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@index([masterId, date])
}

model Appointment {
  id                   String                 @id @default(cuid())
  serviceId            String
  startAt              DateTime
  endAt                DateTime
  customerName         String
  phone                String
  email                String?
  notes                String?
  status               AppointmentStatus      @default(PENDING)
  createdAt            DateTime               @default(now())
  clientId             String?
  /// Связь с мастером (optional — для обратной совместимости)
  masterId             String?
  birthDate            DateTime?
  referral             String?
  paymentStatus        PaymentStatus          @default(PENDING)
  deletedAt            DateTime?              @db.Timestamp(6)
  deletedBy            String?
  /// Язык клиента при бронировании (для email/sms уведомлений): "de", "ru", "en"
  locale               String?                @default("de")
  client               Client?                @relation(fields: [clientId], references: [id])
  master               Master?                @relation(fields: [masterId], references: [id])
  service              Service                @relation(fields: [serviceId], references: [id])
  smsPhoneRegistration SmsPhoneRegistration?
  telegramVerification TelegramVerification?
  statusLogs           AppointmentStatusLog[]

  @@index([masterId])
  @@index([serviceId])
  @@index([status])
  @@index([clientId])
  @@index([startAt, endAt])
  @@index([masterId, startAt])
  @@index([birthDate])
  @@index([paymentStatus])
  @@index([deletedAt])
  @@index([masterId, startAt], map: "appointment_master_time_idx")
  @@map("Appointment")
}

model WorkingHours {
  id           String   @id @default(cuid())
  weekday      Int      @unique
  startMinutes Int
  endMinutes   Int
  isClosed     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model TimeOff {
  id           String   @id @default(cuid())
  date         DateTime
  startMinutes Int
  endMinutes   Int
  reason       String?
  createdAt    DateTime @default(now())

  @@index([date])
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  phone        String?
  image        String?
  role         Role      @default(USER)
  passwordHash String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  accounts     Account[]
  client       Client?
  master       Master?
  sessions     Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OrphanedUser {
  id           String   @id @default(cuid())
  email        String   @unique
  role         Role
  name         String?
  sourceUserId String?
  archivedAt   DateTime @default(now())

  @@index([archivedAt])
}

model Promotion {
  id        String          @id @default(cuid())
  title     String
  percent   Int
  from      DateTime
  to        DateTime
  isGlobal  Boolean         @default(false)
  createdAt DateTime        @default(now())
  items     PromotionItem[]

  @@index([from])
  @@index([to])
  @@index([isGlobal])
}

model PromotionItem {
  id          String    @id @default(cuid())
  promotionId String
  serviceId   String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([promotionId, serviceId])
  @@index([serviceId])
}

model ClientDiscount {
  id        String   @id @default(cuid())
  clientId  String   @unique
  percent   Int
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@index([used])
}

model BookingDraft {
  id           String    @id @default(cuid())
  serviceId    String
  masterId     String
  startAt      DateTime
  endAt        DateTime
  customerName String
  phone        String
  email        String
  birthDate    DateTime?
  referral     String?
  notes        String?
  createdAt    DateTime  @default(now())
  /// Язык клиента при бронировании: "de", "ru", "en"
  locale       String?   @default("de")

  @@index([serviceId])
  @@index([masterId])
  @@index([startAt, endAt])
}

model GoogleUser {
  id        String   @id @default(cuid())
  email     String   @unique
  googleId  String   @unique
  firstName String?
  lastName  String?
  picture   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([googleId])
  @@index([email])
}

model GoogleVerificationRequest {
  id            String   @id @default(cuid())
  email         String
  draftId       String
  state         String   @unique
  expiresAt     DateTime
  verified      Boolean  @default(false)
  appointmentId String?
  createdAt     DateTime @default(now())

  @@index([email, draftId])
  @@index([state])
  @@index([expiresAt])
  @@index([verified])
}

model GoogleQuickRegistration {
  id            String    @id @default(cuid())
  state         String    @unique
  serviceId     String
  masterId      String
  startAt       DateTime
  endAt         DateTime
  email         String?
  expiresAt     DateTime
  verified      Boolean   @default(false)
  appointmentId String?
  createdAt     DateTime  @default(now())
  birthDate     DateTime?
  customerName  String?
  /// Язык клиента при бронировании: "de", "ru", "en"
  locale        String?   @default("de")

  @@index([state])
  @@index([verified])
  @@index([expiresAt])
}

model SmsPhoneRegistration {
  id            String       @id @default(cuid())
  state         String       @unique
  phone         String
  pinCode       String
  pinExpiresAt  DateTime
  attempts      Int          @default(0)
  serviceId     String
  masterId      String
  startAt       DateTime
  endAt         DateTime
  customerName  String?
  email         String?
  birthDate     DateTime?
  verified      Boolean      @default(false)
  appointmentId String?      @unique
  expiresAt     DateTime
  createdAt     DateTime     @default(now())
  /// Язык клиента при бронировании: "de", "ru", "en"
  locale        String?      @default("de")
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  master        Master       @relation(fields: [masterId], references: [id], onDelete: Cascade)
  service       Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@index([verified])
  @@index([expiresAt])
}

model TelegramVerification {
  id             String       @id @default(cuid())
  phone          String
  telegramUserId BigInt?
  code           String
  sessionId      String       @unique
  verified       Boolean      @default(false)
  serviceId      String
  masterId       String
  startAt        String
  endAt          String
  email          String?
  birthDate      DateTime?
  appointmentId  String?      @unique
  createdAt      DateTime     @default(now())
  expiresAt      DateTime
  /// Язык клиента при бронировании: "de", "ru", "en"
  locale         String?      @default("de")
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([sessionId])
  @@index([phone])
  @@index([telegramUserId])
}

model TelegramUser {
  id             String   @id
  email          String?  @unique
  telegramUserId BigInt   @unique
  telegramChatId BigInt   @unique
  firstName      String?
  lastName       String?
  username       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  phone          String   @unique

  @@index([telegramChatId])
  @@index([phone])
}

model TemporarySlotReservation {
  id        String   @id @default(cuid())
  masterId  String
  startAt   DateTime
  endAt     DateTime
  sessionId String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([masterId, startAt, endAt])
  @@index([expiresAt])
}

/// История изменений статуса заявок
model AppointmentStatusLog {
  id             String             @id @default(cuid())
  appointmentId  String
  status         AppointmentStatus
  previousStatus AppointmentStatus?
  changedAt      DateTime           @default(now())
  changedBy      String?
  reason         String?
  appointment    Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([changedAt])
  @@map("appointment_status_logs")
}

model AdminOTP {
  id           String    @id @default(cuid())
  code         String
  action       String
  resourceId   String
  resourceType String
  adminEmail   String
  expiresAt    DateTime
  verified     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  usedAt       DateTime?

  @@index([code])
  @@index([adminEmail])
  @@index([expiresAt])
  @@map("admin_otp")
}

enum ArticleType {
  NEWS
  PROMO
  ARTICLE
}

enum VideoType {
  UPLOAD
  YOUTUBE
  VIMEO
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  DONE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum Role {
  USER
  MASTER
  ADMIN
}

model AiChatSession {
  id              String   @id @default(cuid())

  /// Client-generated session UUID
  sessionId       String   @unique
  
  /// Detected language: "de" | "ru" | "en"
  locale          String   @default("de") @db.VarChar(5)

  /// User-Agent string (truncated to 512 chars)
  userAgent       String?  @db.VarChar(512)

  /// Device type derived from UA: "mobile" | "desktop" | "tablet" | "unknown"
  deviceType      String   @default("unknown") @db.VarChar(16)

  /// IP address (anonymized: last octet zeroed for IPv4)
  ipAnon          String?  @db.VarChar(45)

  /// Referrer page where chat was opened
  referrer        String?  @db.VarChar(512)

  /// Whether voice input was used at least once
  usedVoice       Boolean  @default(false)

  /// Whether streaming (SSE) was used
  usedStreaming    Boolean  @default(false)

  /// Total user messages sent
  messageCount    Int      @default(0)

  /// Total assistant messages
  assistantMsgCount Int    @default(0)

  /// Number of GPT calls (not fast-path)
  gptCallCount    Int      @default(0)

  /// Number of fast-path responses (no GPT)
  fastPathCount   Int      @default(0)

  /// Total tool invocations
  toolCallCount   Int      @default(0)

  /// Cumulative tool execution time (ms)
  toolTotalMs     Int      @default(0)

  /// Number of errors during session
  errorCount      Int      @default(0)

  /// Number of retries triggered
  retryCount      Int      @default(0)

  /// Furthest booking funnel stage reached:
  ///   "none" | "catalog" | "master" | "date" | "slot" | "contact" | "otp" | "completed"
  funnelStage     String   @default("none") @db.VarChar(24)

  /// Whether booking was successfully completed
  bookingCompleted Boolean @default(false)

  /// ID of the created Appointment (if booking completed)
  appointmentId   String?

  /// Whether consultation mode was entered
  consultationUsed Boolean @default(false)

  /// Consultation topics explored (comma-separated)
  consultationTopics String? @db.VarChar(256)

  /// Detailed per-turn records for this session
  turns           AiChatTurn[]

  /// Session start (first message)
  startedAt       DateTime @default(now())

  /// Session end (last activity)
  endedAt         DateTime @default(now())

  /// Duration in seconds (computed on finalize)
  durationSec     Int      @default(0)

  /// Created timestamp
  createdAt       DateTime @default(now())

  /// Last update
  updatedAt       DateTime @updatedAt

  @@index([startedAt])
  @@index([locale])
  @@index([bookingCompleted])
  @@index([funnelStage])
  @@index([deviceType])
  @@map("ai_chat_session")
}

/// One user message -> assistant response cycle
model AiChatTurn {
  id               String     @id @default(cuid())

  /// References AiChatSession.sessionId
  sessionId        String

  /// Sequential turn number within session (1, 2, 3...)
  turnNumber       Int

  /// User message (PII-redacted)
  userMessage      String?    @db.Text

  /// Assistant response text (PII-redacted)
  assistantMessage String?    @db.Text

  /// Response mode: "json" (fast-path or non-streaming) | "sse" (streaming)
  responseMode     String     @default("json") @db.VarChar(8)

  /// Whether this was a fast-path (no GPT call)
  isFastPath       Boolean    @default(false)

  /// Fast-path identifier
  fastPathName     String?    @db.VarChar(64)

  /// Whether GPT was called
  isGptCall        Boolean    @default(false)

  /// Number of GPT iterations (tool loops) in this turn
  gptIterations    Int        @default(0)

  /// Time to first delta in SSE mode (ms)
  ttfdMs           Int?

  /// Total response time from request start to final response (ms)
  totalMs          Int        @default(0)

  /// Booking funnel stage at end of this turn
  funnelStage      String     @default("none") @db.VarChar(24)

  /// Turn outcome: ok | error | timeout | aborted | degraded
  outcome          String     @default("ok") @db.VarChar(16)

  /// Error details (if outcome != ok)
  errorCategory    String?    @db.VarChar(32)
  errorCode        String?    @db.VarChar(64)
  errorMessageSafe String?    @db.VarChar(512)

  /// Whether retry was attempted
  retried          Boolean    @default(false)

  /// Input mode from client
  inputMode        String?    @db.VarChar(8)

  /// Tool runs within this turn
  toolRuns         AiToolRun[]

  /// Timestamps
  startedAt        DateTime   @default(now())
  endedAt          DateTime   @default(now())
  createdAt        DateTime   @default(now())

  /// Relation to session
  session          AiChatSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId, turnNumber])
  @@index([sessionId])
  @@index([startedAt])
  @@index([outcome])
  @@index([errorCategory])
  @@map("ai_chat_turn")
}

/// One tool invocation within a turn
model AiToolRun {
  id               String     @id @default(cuid())

  /// Parent turn
  turnId           String

  /// Tool name (e.g. list_services, search_availability)
  toolName         String     @db.VarChar(64)

  /// Progress step label (if available)
  step             String?    @db.VarChar(64)

  /// Execution order within the turn (0, 1, 2...)
  orderIndex       Int        @default(0)

  /// Duration in milliseconds
  durationMs       Int        @default(0)

  /// Whether execution succeeded
  ok               Boolean    @default(true)

  /// Error details if failed
  errorCode        String?    @db.VarChar(64)
  errorMessageSafe String?    @db.VarChar(512)

  /// Timestamps
  startedAt        DateTime   @default(now())
  createdAt        DateTime   @default(now())

  /// Relation
  turn             AiChatTurn @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@index([turnId])
  @@index([toolName])
  @@map("ai_tool_run")
}

model AiContentBlock {
  id            String   @id @default(cuid())
  key           String   @unique @db.VarChar(128)
  title         String   @db.VarChar(256)
  contentDe     String   @db.Text
  contentRu     String   @db.Text
  contentEn     String   @db.Text
  /// "faq"|"objection"|"aftercare"|"consultation"|"comparison"|"safety"|"upsell"|"occasion"
  context       String   @db.VarChar(32)
  triggerIntent String?  @db.VarChar(64)
  priority      Int      @default(0)
  enabled       Boolean  @default(true)
  serviceSlug   String?  @db.VarChar(128)
  version       Int      @default(1)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([context])
  @@index([triggerIntent])
  @@index([enabled])
  @@map("ai_content_block")
}

model AiServiceConfig {
  id                  String   @id @default(cuid())
  serviceId           String   @unique
  showInConsultation  Boolean  @default(true)
  showInAssistantMenu Boolean  @default(true)
  showInBooking       Boolean  @default(true)
  aiOrder             Int      @default(100)
  aiTags              String?  @db.VarChar(256)
  aiDescriptionDe     String?  @db.Text
  aiDescriptionRu     String?  @db.Text
  aiDescriptionEn     String?  @db.Text
  idealForDe          String?  @db.Text
  idealForRu          String?  @db.Text
  idealForEn          String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([showInConsultation])
  @@index([aiOrder])
  @@map("ai_service_config")
}
